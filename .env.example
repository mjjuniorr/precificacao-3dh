NODE_ENV=development

POSTGRES_DB=precificacao
POSTGRES_USER=precificacao
POSTGRES_PASSWORD=precificacao_dev
DATABASE_URL=postgres://precificacao:precificacao_dev@localhost:5432/precificacao

API_PORT=4000
FRONTEND_PORT=8796
VITE_API_URL=http://localhost:4000
AUTH_MODE=hybrid
APP_PASSWORD=admin
JWT_SECRET=dev-secret-change-me
OIDC_ISSUER=http://localhost:8080/realms/3dh
OIDC_JWKS_URL=http://host.docker.internal:8080/realms/3dh/protocol/openid-connect/certs
OIDC_CLIENT_ID=precificacao-web
OIDC_AUDIENCE=precificacao-web
PORTAL_URL=http://localhost:4180

GHCR_OWNER=mjjuniorr

